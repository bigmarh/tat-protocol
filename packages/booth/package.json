{
  "name": "@tat-protocol/booth",
  "repository": {
    "type": "git",
    "url": "https://github.com/bigmarh/tat-protocol.git",
    "directory": "packages/booth"
  },
  "homepage": "https://github.com/bigmarh/tat-protocol#readme",
  "bugs": "https://github.com/bigmarh/tat-protocol/issues",
  "version": "1.3.0",
  "description": "Booth Agent for TAT Protocol - Purchase and sales protocol",
  "type": "module",
  "main": "dist-cjs/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist-cjs/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "dist-cjs"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc -b && tsc -p tsconfig.cjs.json && node ./scripts/write-cjs-package-json.cjs",
    "test": "jest",
    "lint": "eslint .",
    "format": "prettier --write \"**/*.ts\"",
    "clean": "rm -rf dist dist-cjs && rm tsconfig.tsbuildinfo"
  },
  "keywords": [
    "tat-protocol",
    "nostr",
    "token",
    "commerce",
    "payments",
    "invoice"
  ],
  "author": "TAT Protocol",
  "license": "MIT",
  "dependencies": {
    "@tat-protocol/nwpc": "workspace:*",
    "@tat-protocol/storage": "workspace:*",
    "@tat-protocol/token": "workspace:*",
    "@tat-protocol/hdkeys": "workspace:*",
    "@tat-protocol/utils": "workspace:*"
  },
  "devDependencies": {},
  "module": "dist/index.js"
}
