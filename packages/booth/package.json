{
  "name": "@tat-protocol/booth",
  "version": "1.1.0",
  "description": "Booth Agent for TAT Protocol - Purchase and sales protocol",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc -b",
    "test": "jest",
    "lint": "eslint .",
    "format": "prettier --write \"**/*.ts\"",
    "clean": "rm -rf dist && rm tsconfig.tsbuildinfo"
  },
  "keywords": [
    "tat-protocol",
    "booth",
    "sales",
    "commerce",
    "agent",
    "nwpc"
  ],
  "author": "TAT Protocol",
  "license": "MIT",
  "dependencies": {
    "@tat-protocol/nwpc": "workspace:*",
    "@tat-protocol/storage": "workspace:*",
    "@tat-protocol/token": "workspace:*",
    "@tat-protocol/hdkeys": "workspace:*",
    "@tat-protocol/utils": "workspace:*"
  },
  "devDependencies": {}
}
