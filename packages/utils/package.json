{
  "name": "@tat-protocol/utils",
  "repository": {
    "type": "git",
    "url": "https://github.com/bigmarh/tat-protocol.git",
    "directory": "packages/utils"
  },
  "homepage": "https://github.com/bigmarh/tat-protocol#readme",
  "bugs": "https://github.com/bigmarh/tat-protocol/issues",
  "version": "1.1.1",
  "description": "Utility functions for TAT Protocol",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc -b",
    "test": "jest",
    "lint": "eslint . --ext .ts",
    "format": "prettier --write \"**/*.ts\"",
    "clean": "rm -rf dist && rm tsconfig.tsbuildinfo"
  },
  "keywords": [
    "tat-protocol",
    "nostr",
    "token",
    "crypto",
    "utilities"
  ],
  "author": "TAT Protocol",
  "license": "MIT",
  "dependencies": {
    "@noble/curves": "^1.4.0",
    "@noble/hashes": "^1.0.0",
    "@tat-protocol/hdkeys": "workspace:*",
    "@tat-protocol/types": "workspace:*",
    "nostr-tools": "^2.12.0"
  },
  "devDependencies": {}
}
