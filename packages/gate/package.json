    "directory": "packages/gate"
  },
  "homepage": "https://github.com/bigmarh/tat-protocol#readme",
  "bugs": "https://github.com/bigmarh/tat-protocol/issues",
  "version": "1.1.1",
  "description": "Gate Agent for TAT Protocol - Access verification and validation",
  "type": "module",
