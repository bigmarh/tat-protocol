{
    "name": "@tat-protocol/signers",
    "version": "1.0.1",
    "description": "Signer implementations for TAT Protocol",
    "type": "module",
    "main": "dist/index.js",
    "types": "dist/index.d.ts",
    "exports": {
        ".": {
            "import": "./dist/index.js",
            "types": "./dist/index.d.ts"
        }
    },
    "files": [
        "dist",
        "README.md"
    ],
    "scripts": {
        "build": "tsc -b",
        "test": "jest --passWithNoTests",
        "lint": "eslint . --ext .ts",
        "format": "prettier --write \"**/*.ts\"",
        "clean": "rm -rf dist && rm -f tsconfig.tsbuildinfo"
    },
    "keywords": [
        "signers",
        "tat",
        "protocol",
        "nostr",
        "nip07"
    ],
    "author": "TAT Protocol",
    "license": "MIT",
    "publishConfig": {
        "access": "public"
    },
    "dependencies": {
        "@noble/curves": "^1.4.0",
        "@noble/hashes": "^1.0.0",
        "@tat-protocol/types": "workspace:*",
        "nostr-tools": "^2.12.0"
    },
    "devDependencies": {}
}
