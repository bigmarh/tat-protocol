{
  "name": "@tat-protocol/pocket",
  "version": "1.0.4",
  "description": "Pocket module for TAT Protocol",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc -b",
    "dev": "npx tsx src/examples/runPocket.ts",
    "dev:watch": "npx tsx watch src/examples/runPocket.ts",
    "clean": "rm -rf dist && rm tsconfig.tsbuildinfo"
  },
  "keywords": [
    "pocket",
    "wallet",
    "storage"
  ],
  "author": "TAT Protocol",
  "license": "MIT",
  "dependencies": {
    "@tat-protocol/config": "workspace:*",
    "@tat-protocol/hdkeys": "workspace:*",
    "@tat-protocol/nwpc": "workspace:*",
    "@tat-protocol/signers": "workspace:*",
    "@tat-protocol/storage": "workspace:*",
    "@tat-protocol/types": "workspace:*",
    "@tat-protocol/utils": "workspace:*",
    "nostr-tools": "^2.12.0"
  }
}
