{
  "name": "@tat-protocol/pocket",
  "repository": {
    "type": "git",
    "url": "https://github.com/bigmarh/tat-protocol.git",
    "directory": "packages/pocket"
  },
  "homepage": "https://github.com/bigmarh/tat-protocol#readme",
  "bugs": "https://github.com/bigmarh/tat-protocol/issues",
  "version": "1.3.0",
  "description": "Pocket module for TAT Protocol",
  "type": "module",
  "main": "dist-cjs/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist-cjs/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "dist-cjs"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc -b && tsc -p tsconfig.cjs.json && node ./scripts/write-cjs-package-json.cjs",
    "dev": "npx tsx src/examples/runPocket.ts",
    "dev:watch": "npx tsx watch src/examples/runPocket.ts",
    "clean": "rm -rf dist dist-cjs && rm tsconfig.tsbuildinfo"
  },
  "keywords": [
    "tat-protocol",
    "nostr",
    "token",
    "wallet",
    "transfer"
  ],
  "author": "TAT Protocol",
  "license": "MIT",
  "dependencies": {
    "@tat-protocol/config": "workspace:*",
    "@tat-protocol/hdkeys": "workspace:*",
    "@tat-protocol/nwpc": "workspace:*",
    "@tat-protocol/signers": "workspace:*",
    "@tat-protocol/storage": "workspace:*",
    "@tat-protocol/token": "workspace:*",
    "@tat-protocol/types": "workspace:*",
    "@tat-protocol/utils": "workspace:*",
    "nostr-tools": "^2.12.0"
  },
  "module": "dist/index.js"
}
