{
  "name": "@tat-protocol/nwpc",
  "repository": {
    "type": "git",
    "url": "https://github.com/bigmarh/tat-protocol.git",
    "directory": "packages/nwpc"
  },
  "homepage": "https://github.com/bigmarh/tat-protocol#readme",
  "bugs": "https://github.com/bigmarh/tat-protocol/issues",
  "version": "1.1.1",
  "description": "NWPC (Nostr Wrapped Procedure Call) implementation for TAT Protocol",
  "type": "module",
  "main": "dist-cjs/index.js",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist-cjs/index.js"
    }
  },
  "files": [
    "dist",
    "dist-cjs",
    "lib",
    "README.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc -b && tsc -p tsconfig.cjs.json && node ./scripts/write-cjs-package-json.cjs",
    "test": "jest",
    "lint": "eslint . --ext .ts",
    "format": "prettier --write \"**/*.ts\"",
    "clean": "rm -rf dist dist-cjs && rm tsconfig.tsbuildinfo"
  },
  "keywords": [
    "tat-protocol",
    "nostr",
    "token",
    "rpc",
    "encrypted",
    "nostr-relay"
  ],
  "author": "TAT Protocol",
  "license": "MIT",
  "dependencies": {
    "@tat-protocol/config": "workspace:*",
    "@tat-protocol/types": "workspace:*",
    "@tat-protocol/utils": "workspace:*",
    "nostr-tools": "^2.12.0",
    "readline": "^1.3.0"
  },
  "peerDependencies": {
    "@tat-protocol/storage": "workspace:*"
  }
}
