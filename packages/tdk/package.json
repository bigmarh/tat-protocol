{
  "name": "@tat-protocol/tdk",
  "repository": {
    "type": "git",
    "url": "https://github.com/bigmarh/tat-protocol.git",
    "directory": "packages/tdk"
  },
  "homepage": "https://github.com/bigmarh/tat-protocol#readme",
  "bugs": "https://github.com/bigmarh/tat-protocol/issues",
  "license": "MIT",
  "keywords": [
    "tat-protocol",
    "nostr",
    "token",
    "sdk",
    "developer-kit"
  ],
  "author": "TAT Protocol",
  "private": false,
  "version": "1.1.1",
  "description": "TAT Protocol - Unified SDK with factory helpers for all protocol packages",
  "type": "module",
  "main": "dist-cjs/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist-cjs/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "dist-cjs"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc -b && tsc -p tsconfig.cjs.json && node ./scripts/write-cjs-package-json.cjs",
    "test": "jest --passWithNoTests",
    "lint": "eslint . --ext .ts",
    "clean": "rm -rf dist dist-cjs && rm tsconfig.tsbuildinfo"
  },
  "dependencies": {
    "@tat-protocol/forge": "workspace:*",
    "@tat-protocol/gate": "workspace:*",
    "@tat-protocol/hdkeys": "workspace:*",
    "@tat-protocol/nwpc": "workspace:*",
    "@tat-protocol/booth": "workspace:*",
    "@tat-protocol/pocket": "workspace:*",
    "@tat-protocol/signers": "workspace:*",
    "@tat-protocol/storage": "workspace:*",
    "@tat-protocol/token": "workspace:*",
    "@tat-protocol/types": "workspace:*",
    "@tat-protocol/utils": "workspace:*"
  },
  "devDependencies": {
    "@jest/globals": "^29.7.0",
    "@types/jest": "^29.5.14",
    "@types/node": "^22.15.21",
    "@types/ws": "^8.5.8",
    "@typescript-eslint/eslint-plugin": "^8.32.1",
    "@typescript-eslint/parser": "^8.32.1",
    "eslint": "^9.15.0",
    "husky": "^9.0.11",
    "jest": "^29.7.0",
    "lint-staged": "^16.0.0",
    "prettier": "^3.2.5",
    "ts-jest": "^29.3.4",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3",
    "ws": "^8.14.2",
    "rimraf": "^5.0.5"
  },
  "engines": {
    "node": ">=16.0.0"
  },
  "packageManager": "pnpm@10.10.0",
  "module": "dist/index.js"
}
