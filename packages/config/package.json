{
  "name": "@tat-protocol/config",
  "repository": {
    "type": "git",
    "url": "https://github.com/bigmarh/tat-protocol.git",
    "directory": "packages/config"
  },
  "homepage": "https://github.com/bigmarh/tat-protocol#readme",
  "bugs": "https://github.com/bigmarh/tat-protocol/issues",
  "version": "1.2.0",
  "description": "Configuration module for TAT Protocol",
  "type": "module",
  "main": "dist-cjs/defaultConfig.js",
  "types": "dist/defaultConfig.d.ts",
  "exports": {
    ".": {
      "types": "./dist/defaultConfig.d.ts",
      "import": "./dist/defaultConfig.js",
      "require": "./dist-cjs/defaultConfig.js"
    },
    "./defaultConfig": {
      "types": "./dist/defaultConfig.d.ts",
      "import": "./dist/defaultConfig.js",
      "require": "./dist-cjs/defaultConfig.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "dist-cjs"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc -b && tsc -p tsconfig.cjs.json && node ./scripts/write-cjs-package-json.cjs",
    "clean": "rm -rf dist dist-cjs && rm tsconfig.tsbuildinfo"
  },
  "keywords": [
    "tat-protocol",
    "nostr",
    "token",
    "configuration"
  ],
  "author": "TAT Protocol",
  "license": "MIT",
  "module": "dist/defaultConfig.js"
}
