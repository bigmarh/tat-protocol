{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "module": "CommonJS",
    "moduleResolution": "Node",
    "outDir": "./dist-cjs",
    "declaration": true,
    "declarationDir": "./dist-cjs",
    "declarationMap": false,
    "composite": false,
    "emitDeclarationOnly": false,
    "baseUrl": "../..",
    "paths": {
      "@tat-protocol/*": [
        "packages/*/dist"
      ],
      "*": [
        "node_modules/*"
      ]
    }
  },
  "include": [
    "."
  ],
  "exclude": [
    "node_modules",
    "dist",
    "dist-cjs",
    "scripts",
    "**/*.test.ts"
  ]
}
