{
  "name": "@tat-protocol/forge",
  "repository": {
    "type": "git",
    "url": "https://github.com/bigmarh/tat-protocol.git",
    "directory": "packages/forge"
  },
  "homepage": "https://github.com/bigmarh/tat-protocol#readme",
  "bugs": "https://github.com/bigmarh/tat-protocol/issues",
  "version": "1.3.0",
  "description": "Forge module for TAT Protocol",
  "type": "module",
  "main": "dist-cjs/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist-cjs/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "dist-cjs"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc -b && tsc -p tsconfig.cjs.json && node ./scripts/write-cjs-package-json.cjs",
    "test": "jest",
    "lint": "eslint .",
    "format": "prettier --write \"**/*.ts\"",
    "clean": "rm -rf dist dist-cjs && rm tsconfig.tsbuildinfo"
  },
  "keywords": [
    "tat-protocol",
    "nostr",
    "token",
    "mint",
    "issuance",
    "fungible"
  ],
  "author": "TAT Protocol",
  "license": "MIT",
  "dependencies": {
    "@noble/hashes": "^1.0.0",
    "@tat-protocol/types": "workspace:*",
    "@tat-protocol/utils": "workspace:*",
    "nostr-tools": "^2.12.0"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^8.18.0",
    "@typescript-eslint/parser": "^8.18.0",
    "eslint": "^9.15.0",
    "@eslint/js": "^9.15.0"
  },
  "peerDependencies": {
    "@tat-protocol/token": "workspace:*",
    "@tat-protocol/nwpc": "workspace:*",
    "@tat-protocol/storage": "workspace:*"
  },
  "module": "dist/index.js"
}
