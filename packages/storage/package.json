{
  "name": "@tat-protocol/storage",
  "repository": {
    "type": "git",
    "url": "https://github.com/bigmarh/tat-protocol.git",
    "directory": "packages/storage"
  },
  "homepage": "https://github.com/bigmarh/tat-protocol#readme",
  "bugs": "https://github.com/bigmarh/tat-protocol/issues",
  "version": "1.2.0",
  "description": "Storage module for TAT Protocol",
  "type": "module",
  "main": "./node.js",
  "browser": "./browser.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "node": {
        "types": "./dist/index.d.ts",
        "import": "./node.js",
        "require": "./node.cjs"
      },
      "browser": {
        "types": "./dist/index.d.ts",
        "import": "./browser.js",
        "require": "./browser.cjs"
      },
      "default": {
        "types": "./dist/index.d.ts",
        "import": "./node.js",
        "require": "./node.cjs"
      }
    }
  },
  "files": [
    "dist",
    "node.js",
    "browser.js",
    "README.md",
    "dist-cjs",
    "node.cjs",
    "browser.cjs"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc -b && tsc -p tsconfig.cjs.json && node ./scripts/write-cjs-package-json.cjs",
    "test": "jest",
    "lint": "eslint . --ext .ts",
    "format": "prettier --write \"**/*.ts\"",
    "clean": "rm -rf dist dist-cjs && rm tsconfig.tsbuildinfo"
  },
  "keywords": [
    "tat-protocol",
    "nostr",
    "token",
    "storage",
    "persistence"
  ],
  "author": "TAT Protocol",
  "license": "MIT",
  "dependencies": {
    "@tat-protocol/utils": "workspace:*"
  },
  "devDependencies": {}
}
